# ============================================================================
# Patitas La Serena — Variables de configuración
#
# OJO: en este proyecto el frontend es estático y NO usa un archivo .env en
# tiempo de ejecución. Estos valores se copian a public/js/config.js
# (la URL y la anon key de Supabase son PÚBLICAS y seguras de exponer:
# la seguridad real la dan las políticas RLS de la base de datos).
#
# Las claves SECRETAS (service_role, VAPID privada) solo se usan en las
# Edge Functions / configuración del servidor, nunca en el cliente.
# ============================================================================

# --- Públicas (van en public/js/config.js) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-publica

# --- Secretas (solo servidor / Edge Functions; NO subir al repo) ---
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# --- Web Push (se generan con: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=tu-vapid-public-key
VAPID_PRIVATE_KEY=tu-vapid-private-key
VAPID_SUBJECT=mailto:tu-correo@ejemplo.cl
